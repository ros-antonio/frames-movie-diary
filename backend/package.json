{
  "name": "frames-movie-diary-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:e2e": "cross-env NODE_ENV=test tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "test": "cross-env NODE_ENV=test vitest run",
    "test:coverage": "cross-env NODE_ENV=test vitest run --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:benchmark": "cross-env NODE_ENV=test tsx prisma/seedBenchmark.ts",
    "db:benchmark:indexes:apply": "cross-env NODE_ENV=test tsx prisma/benchmarkIndexes.ts apply",
    "db:benchmark:indexes:drop": "cross-env NODE_ENV=test tsx prisma/benchmarkIndexes.ts drop"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0",
    "@prisma/client": "^4.14.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "express-slow-down": "^3.1.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "selfsigned": "^5.5.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.23",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.2.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.1",
    "cross-env": "^10.1.0",
    "prisma": "^4.14.0",
    "supertest": "^7.1.3",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^4.1.1"
  }
}
