generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SuspiciousStatus {
  OBSERVED
  REVIEWED
  CLEARED
}

model User {
  id                 String           @id @default(uuid())
  email              String           @unique
  name               String
  passwordHash       String
  roleId             String
  role               Role             @relation(fields: [roleId], references: [id])
  movies             Movie[]
  lists              CustomList[]
  auditLogs          AuditLog[]
  suspiciousFlags    SuspiciousUser[]
  reviewedSuspicious SuspiciousUser[] @relation("SuspiciousReviewedBy")
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique
  users       User[]
  permissions Permission[]
}

model Permission {
  id    String @id @default(uuid())
  name  String @unique
  roles Role[]
}

model Movie {
  id          String        @id @default(uuid())
  movieName   String
  watchDate   DateTime
  rating      Float?
  review      String?
  movieLink   String?
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  frames      Frame[]
  listEntries ListMovie[]
}

model Frame {
  id        String   @id @default(uuid())
  imageUrl  String
  timestamp String
  caption   String
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  movieId   String
}

model CustomList {
  id          String      @id @default(uuid())
  name        String
  description String      @default("")
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  entries     ListMovie[]
}

model ListMovie {
  id      String     @id @default(uuid())
  list    CustomList @relation(fields: [listId], references: [id], onDelete: Cascade)
  listId  String
  movie   Movie      @relation(fields: [movieId], references: [id], onDelete: Cascade)
  movieId String

  @@unique([listId, movieId])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  roleName   String
  actionType String
  entityType String?
  entityId   String?
  details    String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([actionType, createdAt])
  @@index([createdAt])
}

model SuspiciousUser {
  id              String           @id @default(uuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason          String
  score           Int              @default(0)
  status          SuspiciousStatus @default(OBSERVED)
  firstDetectedAt DateTime         @default(now())
  lastDetectedAt  DateTime         @updatedAt
  reviewedAt      DateTime?
  reviewedById    String?
  reviewedBy      User?            @relation("SuspiciousReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@unique([userId, reason])
}
